# kube-prometheus-stack values  managed by Ansible

# ==============================================================================
# 1. Grafana Configuration
# ==============================================================================
grafana:
  enabled: true
  adminUser: "{{ grafana_admin_user }}"
  adminPassword: "{{ grafana_admin_password }}"

  service:
    type: NodePort
    nodePort: {{ grafana_nodeport }}

  # Pre-configure Loki as a datasource
  additionalDataSources:
    - name: Loki
      type: loki
      url: http://{{ prometheus_stack_release_name }}-loki.{{ monitoring_namespace }}.svc.cluster.local:3100
      access: proxy

  # Persist dashboards across restarts
  defaultDashboardsEnabled: true
  defaultDashboardsTimezone: utc

# ==============================================================================
# 2. Prometheus Configuration
# ==============================================================================
prometheus:
  enabled: true

  service:
    type: NodePort
    nodePort: {{ prometheus_nodeport }}

  prometheusSpec:
    retention: "{{ prometheus_retention }}"

    # Scrape all ServiceMonitors across all namespaces
    serviceMonitorSelectorNilUsesHelmValues: false
    podMonitorSelectorNilUsesHelmValues: false

# ==============================================================================
# 3. Alertmanager Configuration
# ==============================================================================
alertmanager:
  enabled: true

  service:
    type: NodePort
    nodePort: {{ alertmanager_nodeport }}
 
# ==============================================================================
# 4. Exporters & Core Metrics
# ==============================================================================
nodeExporter:
  enabled: true
  tolerations:
    - key: node-role.kubernetes.io/control-plane
      operator: Exists
      effect: NoSchedule
    - key: node-role.kubernetes.io/master
      operator: Exists
      effect: NoSchedule

kubeStateMetrics:
  enabled: true

# ==============================================================================
# 5. Loki & Promtail Configuration
# ==============================================================================
loki:
  enabled: true

  service:
    type: NodePort
    nodePort: {{ loki_nodeport }}

  config:
    auth_enabled: false

    ingester:
      chunk_idle_period: 3m
      chunk_block_size: 262144
      chunk_retain_period: 1m

    schema_config:
      configs:
        - from: "2024-01-01"
          store: boltdb-shipper
          object_store: filesystem
          schema: v11
          index:
            prefix: index_
            period: 24h

    storage_config:
      boltdb_shipper:
        active_index_directory: /data/loki/boltdb-shipper-active
        cache_location: /data/loki/boltdb-shipper-cache
        shared_store: filesystem
      filesystem:
        directory: /data/loki/chunks

    limits_config:
      enforce_metric_name: false
      reject_old_samples: true
      reject_old_samples_max_age: 168h

promtail:
  enabled: true

  config:
    clients:
      - url: http://{{ prometheus_stack_release_name }}-loki.{{ monitoring_namespace }}.svc.cluster.local:3100/loki/api/v1/push

    scrape_configs:
      - job_name: kubernetes-pods
        kubernetes_sd_configs:
          - role: pod
        relabel_configs:
          - source_labels: [__meta_kubernetes_pod_node_name]
            target_label: node
          - source_labels: [__meta_kubernetes_namespace]
            target_label: namespace
          - source_labels: [__meta_kubernetes_pod_name]
            target_label: pod
          - source_labels: [__meta_kubernetes_pod_container_name]
            target_label: container
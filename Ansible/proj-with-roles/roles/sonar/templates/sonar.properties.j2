#  sonar.properties  managed by Ansible (sonarqube role)
#  Do not edit manually changes will be overwritten

#  Database 
sonar.jdbc.username={{ sonarqube_db_user }}
sonar.jdbc.password={{ sonarqube_db_pass }}
sonar.jdbc.url=jdbc:postgresql://localhost:5432/{{ sonarqube_db_name }}

#  Paths 
sonar.path.data={{ sonarqube_data_dir }}
sonar.path.logs={{ sonarqube_install_dir }}/logs
sonar.path.temp={{ sonarqube_install_dir }}/temp

#  Web server 
sonar.web.host=0.0.0.0
sonar.web.port=9000

#  JVM options 
sonar.web.javaOpts={{ sonarqube_web_jvm_opts }}
sonar.ce.javaOpts={{ sonarqube_ce_jvm_opts }}

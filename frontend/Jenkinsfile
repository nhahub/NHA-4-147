podTemplate(
    containers: [
        containerTemplate(name: 'node', image: 'node:18-alpine', command: 'cat', ttyEnabled: true),
        containerTemplate(name: 'docker', image: 'docker:20.10-cli', command: 'cat', ttyEnabled: true,privileged: true),
        containerTemplate(name: 'sonar-scanner', image: 'sonarsource/sonar-scanner-cli:latest', command: 'cat', ttyEnabled: true),
        containerTemplate(name: 'trivy', image: 'aquasec/trivy:latest', command: 'cat', ttyEnabled: true)
    ],
    volumes: [ hostPathVolume(mountPath: '/var/run/docker.sock', hostPath: '/var/run/docker.sock') ]
) {
    node(POD_LABEL) {
        
        // ==================== EDIT THIS LINE ONLY ====================
        def DOCKER_REGISTRY = "abdulrahman011" 
        // =============================================================

        def IMAGE_NAME    = "${DOCKER_REGISTRY}/devops_comprehensive_project_depi_front_svc"
        def IMAGE_TAG     = "v${env.BUILD_NUMBER}"
        def SONAR_HOST    = "http://34.201.205.190:9000"
        def SONAR_KEY     = "depi-test-project"
        def MANIFEST_PATH = "k8s/k8s/front/front-deployment-svc.yaml"

        try {
            stage('1. Checkout Code') { 
                checkout scm 
            }

            stage('2. SonarQube Analysis') {
                container('sonar-scanner') {
                    withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                        sh """
                        sonar-scanner \
                          -Dsonar.projectKey=${SONAR_KEY} \
                          -Dsonar.sources=./frontend \
                          -Dsonar.host.url=${SONAR_HOST} \
                          -Dsonar.token=\$SONAR_TOKEN
                        """
                    }
                }
            }

            stage('3. Build Docker Image') {
                container('docker') {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ./frontend"
                }
            }

            stage('4. Trivy Vulnerability Scan') {
                container('trivy') {
                    sh "trivy image --exit-code 0 --severity HIGH ${IMAGE_NAME}:${IMAGE_TAG}"
                    sh "trivy image --exit-code 0 --severity CRITICAL ${IMAGE_NAME}:${IMAGE_TAG}"
                }
            }

            stage('5. Push to DockerHub') {
                container('docker') {
                    withCredentials([usernamePassword(credentialsId: 'docker-cred-gomaa', passwordVariable: 'PASS', usernameVariable: 'USER')]) {
                        sh """
                        echo "\${PASS}" | docker login -u "\${USER}" --password-stdin
                        docker push ${IMAGE_NAME}:${IMAGE_TAG}
                        """
                    }
                }
            }

            stage('6. GitOps: Update K8s Manifest') {
               container('node') {
                    withCredentials([usernamePassword(credentialsId: 'github-cred',
                                                    passwordVariable: 'GPASS',
                                                    usernameVariable: 'GUSER')]) {
                        sh """
                        apk add --no-cache git

                        git config --global --add safe.directory \$WORKSPACE

                        git config --global user.email "jenkins@nhahub.local"
                        git config --global user.name "Jenkins CI Bot"

                        cd \$WORKSPACE

                        sed -i -E "s|image:.*|image: ${IMAGE_NAME}:${IMAGE_TAG}|" ${MANIFEST_PATH}

                        git add ${MANIFEST_PATH}
                        git commit -m "ci(frontend): update image to ${IMAGE_TAG} [skip ci]" || echo "No manifest changes"

                        git push https://\${GUSER}:\${GPASS}@github.com/AliAbdElnasser74/gradution_project.git HEAD:main
                        """
                    }
                }
            }
            
        }
        finally{
            cleanWs()
        }
    }
}
